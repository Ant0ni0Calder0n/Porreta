rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de ayuda
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
    }
    
    function isCommunityMember(communityId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communities[communityId] != null;
    }
    
    function isCommunityAdmin(communityId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.communities[communityId] == 'admin';
    }

    function isSafeOwnUserUpdate() {
      return isAuthenticated() &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isSuperAdmin', 'email', 'createdAt']);
    }

    function isSafeCommunityCreate() {
      return isAuthenticated() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.membersCount == 1 &&
        request.resource.data.isActive == true;
    }
    
    // Reglas para usuarios
    match /users/{userId} {
      allow read: if isUser(userId) || isSuperAdmin();
      allow create: if isUser(userId) && !request.resource.data.keys().hasAny(['isSuperAdmin']);
      allow update: if isSuperAdmin() || (isUser(userId) && isSafeOwnUserUpdate());
      allow delete: if false;
    }
    
    // Reglas para comunidades
    match /communities/{communityId} {
      // Permitir lectura si eres miembro O si estás autenticado (para poder verificar contraseña al unirse)
      allow read: if isAuthenticated();
      allow create: if isSafeCommunityCreate();
      allow update: if isSuperAdmin() || 
                      (isCommunityAdmin(communityId) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'passwordHash', 'boteAmount', 'botePerRound'])) ||
                      (isCommunityMember(communityId) && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['membersCount']));
      allow delete: if isSuperAdmin();
    }
    
    // Reglas para rondas
    match /rounds/{roundId} {
      allow read: if isSuperAdmin() || isCommunityMember(resource.data.communityId);
      allow create: if isAuthenticated() &&
                      request.resource.data.createdBy == request.auth.uid &&
                      isCommunityMember(request.resource.data.communityId);
      allow update: if isSuperAdmin() || isCommunityAdmin(resource.data.communityId);
      allow delete: if isSuperAdmin();
    }
    
    // Reglas para apuestas
    match /bets/{betId} {
      allow read: if isSuperAdmin() || isCommunityMember(resource.data.communityId);
      allow create: if isAuthenticated() &&
                      isCommunityMember(request.resource.data.communityId) &&
                      isUser(request.resource.data.userId);
      allow update: if isUser(resource.data.userId) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.roundId == resource.data.roundId &&
                      request.resource.data.communityId == resource.data.communityId;
      allow delete: if isSuperAdmin();
    }

    // Reglas para configuración global
    match /config/{configId} {
      // Cualquiera puede leer la configuración (necesario para signup y communities)
      allow read: if true;
      // Solo super admin puede escribir
      allow write: if isSuperAdmin();
    }

    // Logs de notificaciones: solo visibles para superadmin, escritos por Cloud Functions
    match /notificationLogs/{logId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }
  }
}
